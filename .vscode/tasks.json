{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build and Run (Debug)",
            "type": "shell",
            "command": "./run.sh",
            "args": ["debug"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "detail": "Build and run the application in debug mode"
        },
        {
            "label": "Build and Run (Release)",
            "type": "shell",
            "command": "./run.sh",
            "args": ["release"],
            "group": "build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "detail": "Build and run the application in release mode"
        }
    ]
}
